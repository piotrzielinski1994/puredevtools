{
  "name": "reqhook",
  "version": "0.1.0",
  "description": "Cross-browser WebExtension for intercepting, rewriting, and mocking HTTP requests/responses.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:chrome": "TARGET=chrome vite",
    "dev:firefox": "TARGET=firefox vite",
    "build:chrome": "TARGET=chrome vite build",
    "build:firefox": "TARGET=firefox vite build",
    "typecheck": "tsc --noEmit",
